# Whistle React SDK — publishable key only (whpk_…). Never put a secret wh_ key in the browser.
# Project → API keys in the Whistle workspace.
NEXT_PUBLIC_WHISTLE_PUBLISHABLE_KEY=whpk_replace_me
NEXT_PUBLIC_WHISTLE_PROJECT_ID=00000000-0000-0000-0000-000000000000

# API base (Whistle Elysia app). Default shown — omit if using this.
# NEXT_PUBLIC_WHISTLE_API_BASE=http://localhost:3001/sdk/whistle/v1

# Dev: run three processes on different ports:
#   whistle/server  → 3001  (this URL)
#   whistle/web       → 3000  (embed iframe /embed/report; react-sdk maps API:3001 → web:3000)
#   examples/furbook  → e.g. 3002  →  bun dev -- -p 3002
